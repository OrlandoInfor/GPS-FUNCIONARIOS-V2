{
  "appId": "com.gpsfuncionarios.v2",
  "appName": "GPS Funcionários v2",
  "webDir": "public",
  "server": {
    "url": "https://gps-funcionarios-v2.onrender.com/funcionario",
    "cleartext": true
  },
  "plugins": {
    "Geolocation": {
      "android": {
        "enableBackgroundLocation": true
      }
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_gps",
      "iconColor": "#2563eb"
    }
  },
  "android": {
    "allowMixedContent": true
  }
}
